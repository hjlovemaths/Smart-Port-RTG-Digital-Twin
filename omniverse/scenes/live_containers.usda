                {
                    uniform token info:id = "UsdPreviewSurface"
                    color3f inputs:diffuseColor = (0.66, 0.52, 0.2)
                    float inputs:roughness = 0.62
                    token outputs:surface
                }
            }

            def Material "Container_dark_navy"
            {
                token outputs:surface.connect = </World/LiveContainers/Looks/Container_dark_navy/PreviewSurface.outputs:surface>

                def Shader "PreviewSurface"
                {
                    uniform token info:id = "UsdPreviewSurface"
                    color3f inputs:diffuseColor = (0.03, 0.06, 0.14)
                    float inputs:roughness = 0.62
                    token outputs:surface
                }
            }
        }

