(
    customLayerData = {
        string bayId = "1C/004"
        string bayMapPattern = "123456"
        double containerActualHeightMeters = 2.5
        int containerColumnCount = 6
        int containerCount = 21
        double containerLengthMeters = 5.15
        int containerSizeFeet = 40
        double containerVisualHeightMeters = 0.904353
        string description = "Runtime container instances generated from live bay-map data"
        string layoutMode = "six_container_columns_plus_one_truck_lane"
        double leftInnerSafetyMeters = 1.2
        string physicsMode = "visual_only_no_collision"
        double rightInnerSafetyMeters = 1.5
        string rowHeights = "1,2,3,4,5,6"
        string rowOrder = "right_to_left"
        int truckLaneCount = 1
        double truckLaneWidthMeters = 5
    }
    defaultPrim = "World"
    metersPerUnit = 1
    upAxis = "Z"
)

def "World"
{
    def Xform "LiveContainers"
    {
        custom string live:bayId = "1C/004"
        custom string live:bayMapPattern = "123456"
        custom float live:containerActualHeightM = 2.5
        custom int live:containerSizeFt = 40
        custom float live:containerVisualHeightM = 0.904353
        custom token live:layoutMode = "six_container_columns_plus_one_truck_lane"
        custom float live:maxStackHeightM = 15
        custom token live:physicsMode = "visual_only_no_collision"

        def "Looks"
        {
            def Material "Container_weathered_blue"
            {
                token outputs:surface.connect = </World/LiveContainers/Looks/Container_weathered_blue/PreviewSurface.outputs:surface>

                def Shader "PreviewSurface"
                {
                    uniform token info:id = "UsdPreviewSurface"
                    color3f inputs:diffuseColor = (0.04, 0.21, 0.48)
                    float inputs:roughness = 0.62
                    token outputs:surface
                }
            }

            def Material "Container_oxide_red"
            {
                token outputs:surface.connect = </World/LiveContainers/Looks/Container_oxide_red/PreviewSurface.outputs:surface>

                def Shader "PreviewSurface"
                {
                    uniform token info:id = "UsdPreviewSurface"
                    color3f inputs:diffuseColor = (0.5, 0.11, 0.055)
                    float inputs:roughness = 0.62
                    token outputs:surface
                }
            }

            def Material "Container_warm_gray"
            {
