#usda 1.0
(
    customLayerData = {
        string collisionStatus = "proxy_pending"
        string description = "SimReady motion layer for the primary middle RTG"
        int hiddenLegacyRopeCount = 16
        string primaryRtg = "/World/PortAndRTG/RTG_PRIMARY_DYNAMIC"
        int ropeCount = 16
        string ropeSystem = "/World/PortAndRTG/RTG_PRIMARY_DYNAMIC/ANIM_CTRL_RTG_GANTRY_TRAVEL/ANIM_CTRL_RTG_TROLLEY_TRAVEL/RTG_DYNAMIC_HOIST_ROPES"
    }
    defaultPrim = "World"
    endTimeCode = 230
    framesPerSecond = 24
    metersPerUnit = 1
    startTimeCode = 1
    timeCodesPerSecond = 24
    upAxis = "Z"
)

def "World"
{
    def PhysicsScene "PhysicsScene"
    {
        vector3f physics:gravityDirection = (0, 0, -1)
        float physics:gravityMagnitude = 9.81
    }

    def Scope "RTGPhysics"
    {
        def PhysicsPrismaticJoint "GantryTravelJoint" (
            prepend apiSchemas = ["PhysicsDriveAPI:linear", "PhysicsArticulationRootAPI"]
        )
        {
            float drive:linear:physics:damping = 1500000
            float drive:linear:physics:maxForce = 50000000
            float drive:linear:physics:stiffness = 5000000
            float drive:linear:physics:targetPosition = 0
            float drive:linear:physics:targetPosition.timeSamples = {
                1: 0,
                159: 0,
                230: 4.2,
            }
            float drive:linear:physics:targetVelocity = 0
            uniform token drive:linear:physics:type = "force"
            uniform token physics:axis = "Y"
            rel physics:body1 = </World/PortAndRTG/RTG_PRIMARY_DYNAMIC/ANIM_CTRL_RTG_GANTRY_TRAVEL>
            float physics:breakForce = inf
            float physics:breakTorque = inf
            bool physics:jointEnabled = 0
            point3f physics:localPos0 = (0, 4.160424, 0)
            point3f physics:localPos1 = (0, 0, 0)
            quatf physics:localRot0 = (0, 0, 0, 1)
            quatf physics:localRot1 = (1, 0, 0, 0)
            float physics:lowerLimit = -50
            float physics:upperLimit = 50
            custom token rtg:axis = "Y"
            custom token rtg:controlMode = "position_drive"
        }

        def PhysicsPrismaticJoint "TrolleyTravelJoint" (
            prepend apiSchemas = ["PhysicsDriveAPI:linear"]
        )
        {
            float drive:linear:physics:damping = 35000
            float drive:linear:physics:maxForce = 8000000
            float drive:linear:physics:stiffness = 160000
            float drive:linear:physics:targetPosition = 0
            float drive:linear:physics:targetPosition.timeSamples = {
                1: 0,
                90: 0,
                150: -2.25,
                230: -2.25,
            }
            float drive:linear:physics:targetVelocity = 0
            uniform token drive:linear:physics:type = "force"
            uniform token physics:axis = "X"
            rel physics:body0 = </World/PortAndRTG/RTG_PRIMARY_DYNAMIC/ANIM_CTRL_RTG_GANTRY_TRAVEL>
            rel physics:body1 = </World/PortAndRTG/RTG_PRIMARY_DYNAMIC/ANIM_CTRL_RTG_GANTRY_TRAVEL/ANIM_CTRL_RTG_TROLLEY_TRAVEL>
            float physics:breakForce = inf
            float physics:breakTorque = inf
            bool physics:jointEnabled = 0
            point3f physics:localPos0 = (-2.25, 0, 0)
            point3f physics:localPos1 = (0, 0, 0)
            quatf physics:localRot0 = (1, 0, 0, 0)
            quatf physics:localRot1 = (1, 0, 0, 0)
            float physics:lowerLimit = -4.5
            float physics:upperLimit = 4.5
            custom token rtg:axis = "X"
            custom token rtg:controlMode = "position_drive"
        }

        def PhysicsPrismaticJoint "HoistVerticalJoint" (
            prepend apiSchemas = ["PhysicsDriveAPI:linear"]
        )
        {
            float drive:linear:physics:damping = 40000
            float drive:linear:physics:maxForce = 10000000
            float drive:linear:physics:stiffness = 180000
            float drive:linear:physics:targetPosition = 0
            float drive:linear:physics:targetPosition.timeSamples = {
